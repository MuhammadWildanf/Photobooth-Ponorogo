# This .gitignore file should be placed at the root of your Unity project.
# Standard Unity .gitignore configuration

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory dumps
*.apk
*.unitypackage
*.aar

# Autogenerated VS/VS Code project files
ExportedObj/
.consulo/
.gradle/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.tlog

# Unity3D generated meta files
/*.pidb.meta
/*.sync.meta

# Unity3D Generated File Groups
sysinfo.txt

# Crashlytics generated file
crashlytics-build.properties

# OS generated files
.DS_Store
Thumbs.db

# Builds/ZIPs in root
/Photobooth ponorogo build/
/Photobooth ponorogo build.rar

# Google Drive Credentials
/Assets/UnityGoogleDrive/Resources/GoogleDriveSettings.asset
/Assets/UnityGoogleDrive/Resources/GoogleDriveSettings.asset.meta

